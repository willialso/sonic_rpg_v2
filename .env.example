API_PORT=8787

# Provider routing
PRIMARY_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Reliability tuning
LLM_DEBUG=0
LLM_THROTTLE_MS=120
LLM_CACHE_TTL_MS=900000
LLM_MAX_BACKOFF_MS=60000
LLM_FETCH_TIMEOUT_MS=4500
LLM_TRANSIENT_RETRIES=0
LLM_STYLE_THRESHOLD=62
LLM_ENABLE_REWRITE=0

# API CORS (required when frontend and API are separate origins)
# Example:
# CORS_ALLOWED_ORIGINS=https://sonic-rpg-v2-frontend.onrender.com
CORS_ALLOWED_ORIGINS=

# Frontend build-time API base (set in frontend/static site environment)
# Example:
# VITE_API_BASE_URL=https://sonic-rpg-v2-api.onrender.com
VITE_API_BASE_URL=
